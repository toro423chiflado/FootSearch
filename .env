# ============================================================
#  Variables para docker compose (cópialo como .env)
#  cp .env.example .env
# ============================================================

# --- Credenciales de las bases de datos ---
PG_USER=footsearch
PG_PASSWORD=footsearch_secret
PG_DATABASE=footsearch
MONGO_USER=footsearch
MONGO_PASSWORD=footsearch_secret

# --- Seguridad (CAMBIA esto en producción) ---
# Genera uno con: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Origen permitido del frontend (CORS) ---
CLIENT_ORIGIN=http://localhost:5173

# --- Sembrar datos de prueba al primer arranque (solo si la BD está vacía) ---
# Útil para la primera vez. Ponlo en false si no quieres datos demo.
SEED_ON_START=true

# --- Clave de administración (SOLO TÚ la tienes) ---
# Para editar estadísticas vía /api/admin/...  Genera una con: openssl rand -hex 24
ADMIN_KEY=123

