# --- Servidor ---
PORT=4000

# --- PostgreSQL (datos relacionales) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=footsearch
PG_PASSWORD=footsearch_secret
PG_DATABASE=footsearch

# --- MongoDB (datos no relacionales: videos, highlights) ---
MONGO_URI=mongodb://footsearch:footsearch_secret@localhost:27017/footsearch?authSource=admin

# --- JWT ---
# En producción usa un secreto largo y aleatorio (ej. `openssl rand -hex 32`)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- CORS ---
CLIENT_ORIGIN=http://localhost:5173

# --- Clave de administración (SOLO TÚ la tienes) ---
ADMIN_KEY=clave_admin_super_secreta_cambiala
